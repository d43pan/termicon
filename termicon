# ── emoji search & prompt ─────────────────────────────────────────────────────

_TERMICON_LAST_RESULTS=()

_termicon_do_search() {
    local query="${1,,}"
    _TERMICON_LAST_RESULTS=()
    for entry in "${TERMICON_EMOJIS[@]}"; do
        local emoji="${entry%%|*}"
        local tags="${entry#*|}"
        if [[ "${tags}" == *"${query}"* ]]; then
            _TERMICON_LAST_RESULTS+=("$emoji")
            printf "    %2d)  %s  %s\n" "${#_TERMICON_LAST_RESULTS[@]}" "$emoji" "$tags"
        fi
    done
    if (( ${#_TERMICON_LAST_RESULTS[@]} == 0 )); then
        printf "    No matches for '%s'. Try another word, or paste any emoji directly.\n" "$1"
    fi
}

# _termicon_emoji_prompt <label>
# Sets TERMICON_PICKED: "" = skip, "QUIT" = stop, else the chosen emoji.
_termicon_emoji_prompt() {
    local label="$1"
    TERMICON_PICKED=""
    _TERMICON_LAST_RESULTS=()

    if command -v fzf &>/dev/null; then
        local result
        result=$(printf '%s\n' "${TERMICON_EMOJIS[@]}" | \
            awk -F'|' '{printf "%-5s %s\n", $1, $2}' | \
            fzf --prompt="  ${label} > " \
                --height=16 \
                --layout=reverse \
                --no-info \
                --bind='esc:abort')
        # Empty result = Esc or Enter on empty = skip
        [[ -n "$result" ]] && TERMICON_PICKED="${result%% *}"
        return
    fi

    # ── text search fallback ──────────────────────────────────────────────────
    local had_results=false
    while true; do
        if $had_results && (( ${#_TERMICON_LAST_RESULTS[@]} > 0 )); then
            printf "    [1-%d] pick, search again, paste emoji directly, or Enter to skip: " \
                "${#_TERMICON_LAST_RESULTS[@]}"
        elif $had_results; then
            # Previous search had no results — remind them they can paste directly
            printf "  %-35s → (search or paste emoji directly) " "$label"
        else
            printf "  %-35s → " "$label"
        fi

        local input
        read -r input < /dev/tty

        # Quit
        [[ "$input" == "q" || "$input" == "quit" ]] && { TERMICON_PICKED="QUIT"; return; }

        # Skip
        [[ -z "$input" ]] && { TERMICON_PICKED=""; return; }

        # Number pick (only valid after we have search results)
        if $had_results && [[ "$input" =~ ^[0-9]+$ ]]; then
            local n="$input"
            if (( n >= 1 && n <= ${#_TERMICON_LAST_RESULTS[@]} )); then
                TERMICON_PICKED="${_TERMICON_LAST_RESULTS[$((n-1))]}"
                return
            fi
            printf "    Out of range, try again.\n"
            continue
        fi

        # Text search (ASCII letters only → keyword search)
        if [[ "$input" =~ ^[a-zA-Z0-9\ _-]+$ ]]; then
            _termicon_do_search "$input"
            had_results=true
            continue
        fi

        # Anything else → treat as a directly-pasted emoji
        TERMICON_PICKED="$input"
        return
    done
}

# ── history helpers ───────────────────────────────────────────────────────────

_termicon_read_history() {
    [[ -f "$HOME/.bash_history" ]] && cat "$HOME/.bash_history"
    # Zsh extended format: ": timestamp:elapsed;command"
    [[ -f "$HOME/.zsh_history" ]] && sed 's/^: [0-9]*:[0-9]*;//' "$HOME/.zsh_history"
}

_termicon_top_ssh() {
    local n="${1:-15}"
    _termicon_read_history | \
        grep -oE '(^|[|&;])\s*ssh\s+[^;|&]+' | \
        sed 's/.*ssh //' | \
        awk '
        {
            flags = "bcDEeFiIJlLmopQRSWw"
            skip = 0
            for (i = 1; i <= NF; i++) {
                if (skip) { skip = 0; continue }
                if ($i ~ /^-.$/ && index(flags, substr($i,2,1))) { skip = 1; continue }
                if ($i ~ /^-/) { continue }
                host = $i
                sub(/.*@/, "", host)
                sub(/:.*/, "", host)
                if (host != "") { print host; break }
            }
        }' | \
        sort | uniq -c | sort -rn | head -n "$n"
}

_termicon_top_dirs() {
    local n="${1:-15}"
    _termicon_read_history | \
        grep -oE '(^|[|&;])\s*cd\s+[^;|&]+' | \
        sed 's/.*cd //' | \
        awk '{print $1}' | \
        grep -E '^[/~]' | \
        sed "s|^~|$HOME|" | \
        sed 's|/$||' | \
        sort | uniq -c | sort -rn | head -n "$n"
}

_termicon_is_configured() {
    local type="$1" key="$2"
    [[ -f "$TERMICON_CONFIG" ]] && grep -qE "^${type}:${key//./\\.} " "$TERMICON_CONFIG"
}

# ── setup wizard ──────────────────────────────────────────────────────────────

_termicon_check_conflicts() {
    local hr="────────────────────────────────────────────────────"
    local conflicts=()

    # Check every shell rc file for a PS1-embedded OSC title sequence
    local rcfiles=()
    [[ -f "$HOME/.bashrc" ]]        && rcfiles+=("$HOME/.bashrc")
    [[ -f "$HOME/.bash_profile" ]]  && rcfiles+=("$HOME/.bash_profile")
    [[ -f "$HOME/.zshrc" ]]         && rcfiles+=("$HOME/.zshrc")
    [[ -f "$HOME/.zsh_profile" ]]   && rcfiles+=("$HOME/.zsh_profile")

    for rcfile in "${rcfiles[@]}"; do
        # Look for un-commented lines that embed OSC 0/1/2 in PS1
        if grep -qE "^\s*PS1=.*\\\\(\[\\\\e\]|033\])0;" "$rcfile" 2>/dev/null || \
           grep -qE "^\s*PS1=.*\\\\e\]0;" "$rcfile" 2>/dev/null; then
            local lineno
            lineno=$(grep -nE "^\s*PS1=.*\\\\[e(033]" "$rcfile" | grep "\\]0;" | head -1 | cut -d: -f1)
            conflicts+=("$rcfile:$lineno")
        fi
    done

    # Check if PROMPT_COMMAND already sets a title (outside of termicon)
    if [[ -n "$PROMPT_COMMAND" ]] && \
       echo "$PROMPT_COMMAND" | grep -qE '\\\\(033|e)\]0;' && \
       ! echo "$PROMPT_COMMAND" | grep -q "_termicon"; then
        conflicts+=("PROMPT_COMMAND (already set in environment)")
    fi

    if (( ${#conflicts[@]} == 0 )); then
        return 0
    fi

    echo ""
    echo "⚠️  Potential conflict detected — your emoji may flash and disappear."
    echo ""
    echo "   Another tool is setting the terminal title and will overwrite termicon."
    echo "   Conflicts found:"
    for c in "${conflicts[@]}"; do
        echo "     $c"
    done
    echo ""
    echo "   Fix: comment out or remove the conflicting PS1 title line, e.g.:"
    echo "     # PS1=\"\[\e]0;\u@\h: \w\a\]\$PS1\""
    echo ""
    echo "   termicon uses PROMPT_COMMAND to set the title instead."
    echo "$hr"
}

cmd_setup() {
    _ensure_config

    local hr="────────────────────────────────────────────────────"
    echo "termicon setup — configure emoji from your shell history"
    echo "$hr"

    _termicon_check_conflicts

    if command -v fzf &>/dev/null; then
        echo "Fuzzy search active (fzf). Type to filter, Enter to pick, Esc to skip."
    else
        echo "Type a keyword to search (e.g. 'cloud', 'prod'), pick a number,"
        echo "or paste any emoji directly — it doesn't have to be in the list."
        echo "Enter to skip, q to quit."
    fi
    echo ""

    # ── SSH hosts ──────────────────────────────────────────────────────────────
    echo "$hr"
    local ssh_raw
    ssh_raw=$(_termicon_top_ssh 15)

    if [[ -z "$ssh_raw" ]]; then
        echo "No SSH commands found in history."
    else
        echo "Top SSH hosts from your history:"
        echo ""
        local hosts=() counts=()
        while IFS=' ' read -r count host; do
            hosts+=("$host")
            counts+=("$count")
            local already=""
            _termicon_is_configured "ssh" "$host" && already=" ✓ configured"
            printf "  %-38s %dx%s\n" "$host" "$count" "$already"
        done <<< "$ssh_raw"
        echo ""

        for i in "${!hosts[@]}"; do
            local host="${hosts[$i]}"
            _termicon_is_configured "ssh" "$host" && continue
            _termicon_emoji_prompt "ssh:$host"
            [[ "$TERMICON_PICKED" == "QUIT" ]] && { echo ""; echo "Stopped."; return; }
            [[ -z "$TERMICON_PICKED" ]] && continue
            cmd_add "ssh" "$host" "$TERMICON_PICKED"
        done
    fi

    # ── Directories ────────────────────────────────────────────────────────────
    echo ""
    echo "$hr"
    local dir_raw
    dir_raw=$(_termicon_top_dirs 15)

    if [[ -z "$dir_raw" ]]; then
        echo "No absolute cd paths found in history."
    else
        echo "Top directories from your history:"
        echo ""
        local dirs=() dir_counts=()
        while IFS=' ' read -r count dir; do
            dirs+=("$dir")
            dir_counts+=("$count")
            local display="${dir/$HOME/\~}"
            local already=""
            _termicon_is_configured "dir" "$dir" && already=" ✓ configured"
            printf "  %-38s %dx%s\n" "$display" "$count" "$already"
        done <<< "$dir_raw"
        echo ""

        for i in "${!dirs[@]}"; do
            local dir="${dirs[$i]}"
            local display="${dir/$HOME/\~}"
            _termicon_is_configured "dir" "$dir" && continue
            _termicon_emoji_prompt "dir:$display"
            [[ "$TERMICON_PICKED" == "QUIT" ]] && { echo ""; echo "Stopped."; return; }
            [[ -z "$TERMICON_PICKED" ]] && continue
            cmd_add "dir" "$dir" "$TERMICON_PICKED"
        done
    fi

    # ── Local default ──────────────────────────────────────────────────────────
    echo ""
    echo "$hr"

    local cur_local=""
    [[ -f "$TERMICON_CONFIG" ]] && cur_local=$(grep "^local " "$TERMICON_CONFIG" | awk '{print $2}')

    if [[ -n "$cur_local" ]]; then
        echo "Local default already set: $cur_local  (use 'termicon local' to change)"
    else
        echo "Local default — shown on all local tabs when no directory rule matches."
        _termicon_emoji_prompt "local default"
        if [[ "$TERMICON_PICKED" == "QUIT" ]]; then
            echo ""; echo "Stopped."
        elif [[ -n "$TERMICON_PICKED" ]]; then
            _ensure_config
            local tmpfile
            tmpfile=$(mktemp)
            grep -v "^local " "$TERMICON_CONFIG" > "$tmpfile" 2>/dev/null || true
            echo "local $TERMICON_PICKED" >> "$tmpfile"
            mv "$tmpfile" "$TERMICON_CONFIG"
            echo "Set local default: $TERMICON_PICKED"
        fi
    fi

    echo ""
    echo "$hr"
    echo "Done! Run 'termicon list' to review your mappings."
}

# ── config helpers ────────────────────────────────────────────────────────────

_ensure_config() {
    mkdir -p "$(dirname "$TERMICON_CONFIG")"
    touch "$TERMICON_CONFIG"
}

cmd_add() {
    local type="$1" key="$2" emoji="$3"
    if [[ -z "$type" || -z "$key" || -z "$emoji" ]]; then
        echo "Usage: termicon add <ssh|dir> <host|path> <emoji>" >&2
        exit 1
    fi
    if [[ "$type" != "ssh" && "$type" != "dir" ]]; then
        echo "Type must be 'ssh' or 'dir'" >&2
        exit 1
    fi

    _ensure_config

    local tmpfile
    tmpfile=$(mktemp)
    grep -v "^${type}:${key} " "$TERMICON_CONFIG" > "$tmpfile" 2>/dev/null || true
    echo "${type}:${key} ${emoji}" >> "$tmpfile"
    mv "$tmpfile" "$TERMICON_CONFIG"

    echo "Added: ${type}:${key}  →  ${emoji}"
}

cmd_remove() {
    local type="$1" key="$2"
    if [[ -z "$type" || -z "$key" ]]; then
        echo "Usage: termicon remove <ssh|dir> <host|path>" >&2
        exit 1
    fi

    if [[ ! -f "$TERMICON_CONFIG" ]]; then
        echo "No config file found at $TERMICON_CONFIG" >&2
        exit 1
    fi

    local tmpfile
    tmpfile=$(mktemp)
    grep -v "^${type}:${key} " "$TERMICON_CONFIG" > "$tmpfile" 2>/dev/null || true
    mv "$tmpfile" "$TERMICON_CONFIG"

    echo "Removed: ${type}:${key}"
}

cmd_list() {
    if [[ ! -f "$TERMICON_CONFIG" ]] || [[ ! -s "$TERMICON_CONFIG" ]]; then
        echo "No mappings configured yet."
        echo ""
        echo "Try:  termicon setup"
        return
    fi

    local has_local=false has_ssh=false has_dir=false
    while IFS=' ' read -r entry emoji || [[ -n "$entry" ]]; do
        [[ "$entry" == "#"* || -z "$entry" ]] && continue
        [[ "$entry" == "local" ]] && has_local=true
        local etype="${entry%%:*}"
        [[ "$etype" == "ssh" ]] && has_ssh=true
        [[ "$etype" == "dir" ]] && has_dir=true
    done < "$TERMICON_CONFIG"

    if $has_local; then
        local local_emoji
        local_emoji=$(grep "^local " "$TERMICON_CONFIG" | awk '{print $2}')
        printf "Local default:\n  %s  (all local tabs, no directory rule)\n" "$local_emoji"
    fi

    $has_local && ( $has_ssh || $has_dir ) && echo ""

    if $has_ssh; then
        echo "SSH hosts:"
        while IFS=' ' read -r entry emoji || [[ -n "$entry" ]]; do
            [[ "$entry" == "#"* || -z "$entry" || -z "$emoji" ]] && continue
            [[ "${entry%%:*}" != "ssh" ]] && continue
            printf "  %s  %s\n" "$emoji" "${entry#*:}"
        done < "$TERMICON_CONFIG"
    fi

    $has_ssh && $has_dir && echo ""

    if $has_dir; then
        echo "Directories:"
        while IFS=' ' read -r entry emoji || [[ -n "$entry" ]]; do
            [[ "$entry" == "#"* || -z "$entry" || -z "$emoji" ]] && continue
            [[ "${entry%%:*}" != "dir" ]] && continue
            local key="${entry#*:}"
            printf "  %s  %s\n" "$emoji" "${key/$HOME/\~}"
        done < "$TERMICON_CONFIG"
    fi
}

cmd_pick() {
    local type="$1" key="$2"
    if [[ -z "$type" || -z "$key" ]]; then
        echo "Usage: termicon pick <ssh|dir> <host|path>" >&2
        exit 1
    fi
    if [[ "$type" != "ssh" && "$type" != "dir" ]]; then
        echo "Type must be 'ssh' or 'dir'" >&2
        exit 1
    fi

    if command -v fzf &>/dev/null; then
        echo "Fuzzy search — type to filter, Enter to select, Esc to cancel."
    else
        echo "Type a keyword to search (e.g. 'cloud', 'linux'), then pick a number."
        echo "Or paste an emoji directly. Enter to cancel."
    fi
    echo ""

    _termicon_emoji_prompt "${type}:${key}"

    if [[ -z "$TERMICON_PICKED" || "$TERMICON_PICKED" == "QUIT" ]]; then
        echo "No emoji selected, nothing changed."
    else
        cmd_add "$type" "$key" "$TERMICON_PICKED"
    fi
}

cmd_local() {
    local emoji="$1"

    if [[ -z "$emoji" ]]; then
        # No arg — open the picker
        if command -v fzf &>/dev/null; then
            echo "Fuzzy search — type to filter, Enter to select, Esc to cancel."
        else
            echo "Type a keyword to search (e.g. 'home', 'laptop'), pick a number,"
            echo "or paste any emoji directly."
        fi
        echo ""
        _termicon_emoji_prompt "local default"
        if [[ -z "$TERMICON_PICKED" || "$TERMICON_PICKED" == "QUIT" ]]; then
            echo "No emoji selected, nothing changed."
            return
        fi
        emoji="$TERMICON_PICKED"
    fi

    _ensure_config
    local tmpfile
    tmpfile=$(mktemp)
    grep -v "^local " "$TERMICON_CONFIG" > "$tmpfile" 2>/dev/null || true
    echo "local $emoji" >> "$tmpfile"
    mv "$tmpfile" "$TERMICON_CONFIG"
    echo "Set local default:  →  $emoji"
    echo "(All local tabs will use $emoji when no directory rule matches.)"
}

cmd_edit() {
    _ensure_config
    "${EDITOR:-vi}" "$TERMICON_CONFIG"
}

cmd_help() {
    cat <<EOF
termicon — set emoji for terminal tabs per SSH host or directory

Usage:
  termicon setup                                 Wizard: assign emoji from your history
  termicon local [emoji]                         Set default emoji for local sessions
  termicon add <ssh|dir> <host|path> <emoji>     Add or update a mapping
  termicon remove <ssh|dir> <host|path>          Remove a mapping
  termicon list                                  List all mappings
  termicon pick <ssh|dir> <host|path>            Search and assign an emoji
  termicon edit                                  Open config in \$EDITOR
  termicon help                                  Show this help

Examples:
  termicon setup                        # recommended starting point
  termicon local                        # pick default emoji for local tabs
  termicon local 🏠                     # set directly
  termicon add ssh prod.example.com 🚨
  termicon add dir ~/work 💼
  termicon pick ssh staging.example.com # search by keyword or fuzzy (fzf)
  termicon remove dir ~/work

Config file: $TERMICON_CONFIG

Shell plugin — add to your ~/.bashrc or ~/.zshrc:
  source /path/to/termicon/termicon.sh

Tip: install fzf for fuzzy emoji search in setup and pick.
     Without fzf, type keywords like 'cloud', 'prod', 'linux' to filter.
EOF
}

# Only run commands when executed directly, not when sourced
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    case "${1:-help}" in
        setup)          cmd_setup ;;
        local)          cmd_local  "$2" ;;
        add)            cmd_add    "$2" "$3" "$4" ;;
        remove)         cmd_remove "$2" "$3" ;;
        list)           cmd_list ;;
        pick)           cmd_pick   "$2" "$3" ;;
        edit)           cmd_edit ;;
        help|--help|-h) cmd_help ;;
        *)
            echo "Unknown command: $1" >&2
            echo "Run 'termicon help' for usage." >&2
            exit 1
            ;;
    esac
fi
